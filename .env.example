# Copy this file to .env.local and fill in real values.
# .env.local is gitignored and never committed.

# Optional. If unset, the app automatically falls back to a deterministic
# Mock AI provider so the whole product (including tests and CI) runs with
# zero secrets and zero cost. Set this to enable real Claude-generated
# recommendations, translations, and decision support.
ANTHROPIC_API_KEY=

# Model used for all AI calls when ANTHROPIC_API_KEY is set.
ANTHROPIC_MODEL=claude-sonnet-4-6

# Secret used to sign CSRF tokens. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CSRF_SECRET=replace-with-a-long-random-string

# Requests allowed per IP per rate-limit window on AI-backed endpoints.
RATE_LIMIT_MAX=20
RATE_LIMIT_WINDOW_MS=60000
